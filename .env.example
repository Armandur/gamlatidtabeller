# Trafiklab-nycklar (registrera pa trafiklab.se)
# GTFS Regional Static - OBS Bronze-kvot: 60 anrop/30 dagar, cachea alltid
TRAFIKLAB_STATIC_KEY=
# GTFS Regional Realtime - separat nyckel, hog kvot
TRAFIKLAB_RT_KEY=

# Publik bas-URL, anvands i QR-koder pa utskrivna lappar
BASE_URL=http://localhost:8000

# Katalog for cachad GTFS-zip och SQLite-databas
DATA_DIR=data

# Portar nar appen kors via `python -m app.run` (publik + admin i samma
# process). Exponera bara PORT publikt - admin ska ligga privat.
PORT=8000
ADMIN_PORT=8001

# Losenord for admin-granssnittet. Tomt = ingen inloggning (lita pa att
# porten ar privat) - satt det i drift.
ADMIN_PASSWORD=

# Hemlighet for signering av admin-sessionscookies. Tomt = slumpas vid
# varje start (sessioner overlever da inte omstart).
SESSION_SECRET=
